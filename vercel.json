{ "$schema": "https://openapi.vercel.sh/vercel.json", "cleanUrls": true, "trailingSlash": false, "rewrites": [ { "source": "/sitemap.xml", "destination": "/api/sitemap" }, { "source": "/robots.txt", "destination": "/api/robots" }, { "source": "/llms.txt", "destination": "/api/llms" }, { "source": "/proyecto/:slug", "destination": "/api/og/:slug" }, { "source": "/admin", "destination": "/admin.html" }, { "source": "/api/admin/chats/:from/takeover", "destination": "/api/admin/chats/:from?action=takeover" }, { "source": "/api/admin/chats/:from/release", "destination": "/api/admin/chats/:from?action=release" }, { "source": "/api/admin/chats/:from/send", "destination": "/api/admin/chats/:from?action=send" }, { "source": "/api/admin/chats/:from/delete", "destination": "/api/admin/chats/:from?action=delete" }, { "source": "/proyectos", "destination": "/index" }, { "source": "/blog", "destination": "/index" }, { "source": "/contacto", "destination": "/index" }, { "source": "/mapa", "destination": "/index" }, { "source": "/calculadora", "destination": "/index" } ], "headers": [ { "source": "/images/(.*)", "headers": [ { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" } ] }, { "source": "/js/(.*)", "headers": [ { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" } ] }, { "source": "/(.*)", "headers": [ { "key": "X-Content-Type-Options", "value": "nosniff" }, { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }, { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" } ] } ] }
